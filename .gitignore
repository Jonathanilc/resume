# Copy this file to the Git repository and rename it ".gitignore".
# Lines starting with '#' are treated as comments.

############################################
## USER SCRIPTS AND NOTES
############################################

/*.bat
/\!*
.DS_Store
*.pdf

############################################
## LATEX TEMPORARY FILES
############################################

*.log
*.aux
*.bbl
*.blg
*.tex.undo
*.tex.bak
*.~te
*.$te
*.DVX
*.DDF
*.synctex.gz
*.synctex.gz(busy)
*.fdb_latexmk
*.fls
*.out
*.toc
*.lof
*.lot
*.idx
*.ilg
*.ind

*.dvi
*.ps

############################################
# do not upload secret infomation
myresume.tex
myresume.pdf

# Per-company / sensitive variants — keep local only.
# Any folder under variants/ starting with "private-" is ignored entirely.
# (PDFs and LaTeX aux files are already excluded by global rules above.)
variants/private-*/
